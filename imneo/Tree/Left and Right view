#include <bits/stdc++.h>
using namespace std;

struct Node {
    int val;
    Node* left;
    Node* right;

    Node(int val) {
        this->val = val;
        left = NULL;
        right = NULL;
    }
};
Node* insert(vector<int> &arr, int i) {
    if (i >= arr.size() || arr[i] == -1)
        return NULL;

    Node* root = new Node(arr[i]);

    root->left = insert(arr, 2 * i + 1);
    root->right = insert(arr, 2 * i + 2);

    return root;
}

void leftView(Node* root){
    
    if(!root) return;
    
    queue<Node*> q;
    q.push(root);
    
    while(!q.empty()){
        int s = q.size();
        
        for(int i=0;i<s;i++){
            auto node = q.front();
            q.pop();
            
            if(i==0){
                cout<<node->val<<" ";
            }
            if(node->left) q.push(node->left);
            if(node->right) q.push(node->right);
        }
    }
}
void rightView(Node* root){
    
    if(!root) return;
    
    queue<Node*> q;
    q.push(root);
    
    while(!q.empty()){
        int s = q.size();
        
        for(int i=0;i<s;i++){
            auto node = q.front();
            q.pop();
            
            if(i==s-1){
                cout<<node->val<<" ";
            }
            if(node->left) q.push(node->left);
            if(node->right) q.push(node->right);
        }
    }
}

int main() {
    int n;
    cin >> n;

    vector<int> arr(n);

    for (int i = 0; i < n; i++)
        cin >> arr[i];

    Node* root = insert(arr, 0);
    cout<<"Left view: "<<endl;
    leftView(root);
    cout<<endl;
    cout<<"Right view: "<<endl;
    rightView(root);
    
    
    
    return 0;
}
